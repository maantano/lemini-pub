# =============================================================================
# Lemini — Environment Variables Template
# =============================================================================
# 복사: cp .env.example .env
# 그리고 아래 [REQUIRED] 항목들을 본인 값으로 채우세요.
# .env 파일은 절대 git에 커밋되지 않습니다 (.gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=local                              # local / prod
APP_BASE_URL=http://localhost:3000         # 프론트 URL
API_BASE_URL=http://localhost:8000         # 백엔드 URL (서버 사이드)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000  # 프론트(브라우저)에서 호출하는 백엔드 URL
APP_TIMEZONE=Asia/Seoul

# -----------------------------------------------------------------------------
# [REQUIRED] LLM — Google Gemini
# -----------------------------------------------------------------------------
# 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<your-gemini-api-key>                            # AI Studio 키 (필수)
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=256

# -----------------------------------------------------------------------------
# [REQUIRED] 국가법령정보 공동활용 API
# -----------------------------------------------------------------------------
# 발급: https://open.law.go.kr (서버 IP 등록 필요)
# 주의: API 호출은 등록된 IP/도메인에서만 가능
LAW_API_KEY=<your-law-go-kr-oc>                               # OC 값
LAW_OC=<your-law-go-kr-oc>                                    # 동일 (코드 일부에서 별칭으로 사용)

# 예비 (현재 비사용): data.go.kr serviceKey
DATA_GO_KR_SERVICE_KEY=<your-data-go-kr-service-key>

# -----------------------------------------------------------------------------
# [REQUIRED] Admin & Security
# -----------------------------------------------------------------------------
# 강한 랜덤 생성 권장: openssl rand -hex 32
ADMIN_API_KEY=change-me-use-openssl-rand-hex-32
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_EXPIRE_HOURS=72
CORS_ALLOW_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Kakao OAuth (현재 로그인 UI 비활성화 — 데모는 비워둬도 OK)
# 로그인을 다시 켜려면 https://developers.kakao.com 에서 키 발급 후 채우기
# -----------------------------------------------------------------------------
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/auth/callback/
NEXT_PUBLIC_KAKAO_CLIENT_ID=
NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:3000/auth/callback/

# -----------------------------------------------------------------------------
# Retrieval
# -----------------------------------------------------------------------------
RETRIEVAL_TOP_K=6
RETRIEVAL_MIN_SCORE=0.35
RETRIEVAL_NEIGHBOR_EXPAND=0

# -----------------------------------------------------------------------------
# Features (운영 환경에 따라 ON/OFF)
# -----------------------------------------------------------------------------
DAILY_QUESTION_LIMIT=500
ENABLE_SERVER_CHAT_HISTORY=false
ENABLE_ARTICLE_SEGMENT=false
ENABLE_ADMIN_UPLOAD_UI=true
ENABLE_APPENDIX_SEARCH=false
ENABLE_VECTOR_SEARCH=true

# -----------------------------------------------------------------------------
# Local artifacts
# -----------------------------------------------------------------------------
ARTIFACT_DIR=                              # 비우면 ./data/artifacts 사용

# -----------------------------------------------------------------------------
# Web build (optional — Cloudflare/Pages subpath 호스팅 시)
# -----------------------------------------------------------------------------
# WEB_BASE_PATH=/kr-law-rag

# =============================================================================
# 아래는 GCP에 배포할 때만 필요 — 로컬 개발에는 불필요
# =============================================================================

# -----------------------------------------------------------------------------
# GCP 배포용
# -----------------------------------------------------------------------------
PROJECT_ID=<your-gcp-project>
REGION=asia-northeast3
API_SERVICE_NAME=lemini-api

# Cloud Run Jobs
CLOUD_RUN_JOB=lemini-data-sync

# GCS 버킷 (본인 환경에 맞는 이름으로)
GCS_DATA_BUCKET=<your-data-bucket>
GCS_CACHE_BUCKET=<your-cache-bucket>
GCS_BACKUP_BUCKET=<your-backup-bucket>
STATE_DB_BUCKET=<your-state-bucket>
ARTIFACT_BUCKET=<your-law-artifacts-bucket>

# Workspace
WORKSPACE_ROOT=./data/sync
LEGALIZE_CACHE_DIR=./data/legalize-cache

# -----------------------------------------------------------------------------
# Slack Bot (옵션 — Slack 통합 사용 시)
# -----------------------------------------------------------------------------
SLACK_BOT_TOKEN=<your-slack-bot-token>
SLACK_APP_TOKEN=<your-slack-app-token>
SLACK_SIGNING_SECRET=<your-slack-signing-secret>
SLACK_ALERT_CHANNEL=<your-slack-channel>
LEMINI_API_URL=http://localhost:8000      # Slack 봇이 호출할 백엔드 URL

# -----------------------------------------------------------------------------
# Analytics (옵션)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=<your-domain>

# -----------------------------------------------------------------------------
# Mobile (옵션 — Expo 앱)
# -----------------------------------------------------------------------------
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000
